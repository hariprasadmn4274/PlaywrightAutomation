{
  "name": "@rd/e2e-token-fetcher",
  "version": "1.0.10",
  "description": "A simple node module that provides easy-to-use methods for getting authentication cookies and tokens.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlabee.dt.renault.com/shared/components/security/oidc/e2e-token-fetcher.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "E2E_TOKEN_FETCHER_LOGLEVEL=error jest --coverage",
    "test:netiq": "E2E_TOKEN_FETCHER_LOGLEVEL=error jest --coverage test/*netiq*.ts",
    "test:netiq:token": "E2E_TOKEN_FETCHER_LOGLEVEL=error jest --coverage test/*netiq*token*.ts",
    "test:netiq:cookie": "E2E_TOKEN_FETCHER_LOGLEVEL=error jest --coverage test/*netiq*cookie*.ts",
    "test:okta": "E2E_TOKEN_FETCHER_LOGLEVEL=error jest --coverage test/*okta*.ts"
  },
  "keywords": [],
  "author": "arnaud.ruch@renault.com",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://artifactory.dt.renault.com/artifactory/api/npm/npm-renault-local/"
  },
  "dependencies": {
    "@okta/okta-auth-js": "^7.8.0",
    "@types/tough-cookie": "^4.0.5",
    "axios": "^0.27.2",
    "axios-cookiejar-support": "^1.0.1",
    "dotenv": "^16.4.5",
    "http-cookie-agent": "^1.0.6",
    "keepalive-proxy-agent": "^1.3.0",
    "loglevel": "^1.9.2",
    "tough-cookie": "^4.1.4"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
