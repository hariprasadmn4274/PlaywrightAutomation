#!/usr/bin/env node

require('dotenv').config(); // NOSONAR

// Use require to avoid 'SyntaxError: Cannot use import statement outside a module' errors
const sendReportWrapper = require('../lib/cli/send-report').sendReportWrapper; // NOSONAR
const print = require('../lib/utils').print; // NOSONAR

const LINE = '------------------------------------------------------------';

print(LINE);
print('JIRA_XRAY_LOGIN:', process.env.JIRA_XRAY_LOGIN);
print('JIRA_XRAY_PROXY:', process.env.JIRA_XRAY_PROXY);
print(LINE);
print('XC_MERGED_REPORT_DIRECTORY:', process.env.XC_MERGED_REPORT_DIRECTORY);
print('XC_DEFAULT_TEST_PLAN:', process.env.XC_DEFAULT_TEST_PLAN);
print('XC_TEST_ENVIRONMENT:', process.env.XC_TEST_ENVIRONMENT);
print('XC_TEST_FIX_VERSIONS:', process.env.XC_TEST_FIX_VERSIONS);
print(LINE);

sendReportWrapper();
