{
  "name": "@rd/xray-connector",
  "version": "1.0.51",
  "bin": {
    "xray-get-features": "bin/get-features",
    "xray-build-report": "bin/merge-reports",
    "xray-build-gatling-report": "bin/get-gatling-report",
    "xray-send-report": "bin/send-report"
  },
  "description": "This module demonstrates the synchronization between XRay and a Test Automation Framework, for instance `cypress`.",
  "main": "index.js",
  "scripts": {
    "build": "npx prettier --no-editorconfig --write '{src,test}/**/*.ts' --log-level warn && tsc -p .",
    "test:all": "npx nyc --clean --report-dir=coverage/test cucumber-js test/features/**/*.feature",
    "sonar:start": "docker-compose -f sonar-local/docker-compose.sonar.yml up -d",
    "sonar:stop": "docker-compose -f sonar-local/docker-compose.sonar.yml down",
    "test:debug": "npx cucumber-js test/features/**/*.feature --tags=\"@debug\"",
    "test:without-xray": "npx nyc --clean --report-dir=coverage/test_without_xray cucumber-js test/features/**/*.feature --tags=\"not @xray\"",
    "test:with-xray": "npx nyc --clean --report-dir=coverage/test_with_xray cucumber-js test/features/**/*.feature --tags=\"@xray\"",
    "test:sonar": "node sonar-local/sonar-project.js && open http://localhost:9000/dashboard?id=xray-connector"
  },
  "keywords": [],
  "author": "arnaud.ruch@renault.com",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://artifactory.dt.renault.com/artifactory/api/npm/npm-renault-local/"
  },
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "reporter": [
      "lcov"
    ],
    "source-map": true,
    "all": false
  },
  "repository": {
    "type": "git",
    "url": "https://gitlabee.dt.renault.com/shared/components/quality/xray-connector.git"
  },
  "dependencies": {
    "@types/jira-client": "^7.1.9",
    "@types/lodash": "^4.17.9",
    "@types/node": "^20.16.9",
    "@types/unzipper": "^0.10.10",
    "dotenv": "^16.4.5",
    "jira-client": "^8.2.2",
    "jira-client-xray": "^1.0.1",
    "lodash": "^4.17.21",
    "multiple-cucumber-html-reporter": "^3.7.0",
    "node-global-proxy": "^1.0.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.1",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@types/chai": "^4.3.20",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "chai": "^4.5.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "nyc": "^17.1.0",
    "prettier": "^3.3.3",
    "sonarqube-scanner": "^4.2.3",
    "source-map-support": "^0.5.21"
  }
}
