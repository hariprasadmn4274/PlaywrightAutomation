#!/usr/bin/env node

require('dotenv').config(); // NOSONAR

// Use require to avoid 'SyntaxError: Cannot use import statement outside a module' errors
const getFeaturesWrapper = require('../lib/cli/get-features').getFeaturesWrapper; // NOSONAR
const print = require('../lib/utils').print; // NOSONAR

const LINE = '------------------------------------------------------------';

print(LINE);
print('JIRA_XRAY_HOST:', process.env.JIRA_XRAY_HOST);
print('JIRA_XRAY_LOGIN:', process.env.JIRA_XRAY_LOGIN);
print('JIRA_XRAY_PASSWORD is ' + (process.env.JIRA_XRAY_PASSWORD ? '' : 'not ') + 'set');
print('JIRA_XRAY_TOKEN is ' + (process.env.JIRA_XRAY_TOKEN ? '' : 'not ') + 'set');
print('JIRA_XRAY_PROXY:', process.env.JIRA_XRAY_PROXY);
print(LINE);
print('XC_DEFAULT_TEST_PLAN:', process.env.XC_DEFAULT_TEST_PLAN);
print('XC_FEATURES_DOWNLOAD_DIRECTORY:', process.env.XC_FEATURES_DOWNLOAD_DIRECTORY);
print(LINE);

getFeaturesWrapper();
